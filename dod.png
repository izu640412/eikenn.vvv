//]]></script><script src="./dod_files/widget.js.ダウンロード" id="rewards-widget" data-report-activity="false" data-dark-mode="false" data-settings="eyJ2ZXJ0aWNhbCI6ImltYWdlcyIsIm1hcmtldCI6ImphLWpwIn0=" async=""></script><style data-rewards-widget-styles="true" data-style-id="medallion:medallion-main">div[data-rewards-widget].medallion .dailyCheckAnimationContainer {
  height: 32px;
  width: 32px;
  display: flex;
}

div[data-rewards-widget].medallion .dailyCheckAnimationContainer .meter {
  stroke: var(--rw-color, var(--rw-medal-color));
}

div[data-rewards-widget].medallion .dailyCheckAnimationContainer .dmeter {
  stroke: var(--rw-color, #c5c5c5);
}

div[data-rewards-widget].medallion .dailyCheckAnimationContainer .progress {
  stroke: var(--rw-color, #00b7ab);
}

div[data-rewards-widget].medallion .dailyCheckAnimationContainer .checkmark {
  stroke: var(--rw-color, #00b7ab);
}

div[data-rewards-widget].medallion .dailyCheckAnimationContainer .medal-circled {
  fill: var(--rw-color, var(--rw-medal-color));
}

div[data-rewards-widget].medallion .dailyCheckAnimationContainer .completedmeter {
  stroke: var(--rw-color, #00b7ab);
}

div[data-rewards-widget].medallion .dailyCheckAnimationContainer .overlapWithAbove {
  position: absolute;
  width: 32px;
  height: 32px;
}

div[data-rewards-widget].medallion .dailyCheckAnimationContainer .progressSvg {
  position: absolute;
  width: 32px;
  height: 32px;
}

div[data-rewards-widget].medallion .dailyCheckAnimationContainer .overlapWithAbove2 {
  position: absolute;
  top: 9px;
  left: 7px;
  width: 18px;
  height: 18px;
}

div[data-rewards-widget].medallion .parentContainer {
  position: relative;
  width: 32px;
  height: 32px;
}

div[data-rewards-widget].medallion .firework,
.firework::before,
.firework::after {
  position: absolute;
  top: 16px;
  left: 16px;
  transform: translate(-50%, -50%);
  width: 0vmin;
  aspect-ratio: 1;
  background: radial-gradient(circle, #7fdbff 0.4vmin, rgba(245, 245, 245, 0) 0 0) 50% 0%,
    radial-gradient(circle, #39cccc 0.4vmin, rgba(245, 245, 245, 0) 0 0) 0% 50%,
    radial-gradient(circle, #96e8de 0.5vmin, rgba(245, 245, 245, 0) 0 0) 50% 99%,
    radial-gradient(circle, #00b7ab 0.4vmin, rgba(245, 245, 245, 0) 0 0) 99% 50%,
    radial-gradient(circle, #39cccc 0.6vmin, rgba(245, 245, 245, 0) 0 0) 80% 90%,
    radial-gradient(circle, #96e8de 0.5vmin, rgba(245, 245, 245, 0) 0 0) 95% 90%,
    radial-gradient(circle, #39cccc 0.5vmin, rgba(245, 245, 245, 0) 0 0) 10% 60%,
    radial-gradient(circle, #39cccc 0.4vmin, rgba(245, 245, 245, 0) 0 0) 31% 80%,
    radial-gradient(circle, #00b7ab 0.3vmin, rgba(245, 245, 245, 0) 0 0) 80% 10%,
    radial-gradient(circle, #96e8de 0.6vmin, rgba(245, 245, 245, 0) 0 0) 90% 23%,
    radial-gradient(circle, #7fdbff 0.3vmin, rgba(245, 245, 245, 0) 0 0) 45% 20%,
    radial-gradient(circle, #39cccc 0.5vmin, rgba(245, 245, 245, 0) 0 0) 15% 60%,
    radial-gradient(circle, #39cccc 0.4vmin, rgba(245, 245, 245, 0) 0 0) 41% 80%,
    radial-gradient(circle, #00b7ab 0.3vmin, rgba(245, 245, 245, 0) 0 0) 85% 20%,
    radial-gradient(circle, #96e8de 0.6vmin, rgba(245, 245, 245, 0) 0 0) 95% 40%,
    radial-gradient(circle, #7fdbff 0.3vmin, rgba(245, 245, 245, 0) 0 0) 45% 10%,
    radial-gradient(circle, #00b7ab 0.3vmin, rgba(245, 245, 245, 0) 0 0) 84% 10%,
    radial-gradient(circle, #96e8de 0.5vmin, rgba(245, 245, 245, 0) 0 0) 95% 23%,
    radial-gradient(circle, #7fdbff 0.3vmin, rgba(245, 245, 245, 0) 0 0) 45% 23%,
    radial-gradient(circle, #39cccc 0.5vmin, rgba(245, 245, 245, 0) 0 0) 15% 62%,
    radial-gradient(circle, #39cccc 0.4vmin, rgba(245, 245, 245, 0) 0 0) 41% 55%,
    radial-gradient(circle, #00b7ab 0.3vmin, rgba(245, 245, 245, 0) 0 0) 85% 27%,
    radial-gradient(circle, #96e8de 0.6vmin, rgba(245, 245, 245, 0) 0 0) 95% 21%,
    radial-gradient(circle, #7fdbff 0.3vmin, rgba(245, 245, 245, 0) 0 0) 45% 20%,
    radial-gradient(circle, #7fdbff 0.5vmin, rgba(245, 245, 245, 0) 0 0) 13% 24%;
  background-size: 1.5vmin 1.5vmin;
  background-repeat: no-repeat;
  animation-delay: 1s;
  animation: firework 1s;
}

@keyframes firework {
  0% {
    width: 1.5vmin;
    opacity: 20;
  }

  100% {
    width: 12vmin;
    opacity: 0;
  }
}

/*# sourceMappingURL=data:application/json;charset=utf-8;base64, */div[data-rewards-widget].medallion .gaining-points-animation {
  width: inherit;
  height: 32px;
}

div[data-rewards-widget].medallion .gaining-points-animation .circle-animation-container {
  position: relative;
}

div[data-rewards-widget].medallion .gaining-points-animation .outer-circle-animation {
  animation: rw-gp-expand-collapse 0.3s cubic-bezier(0.075, 0.82, 0.165, 1);
  animation-delay: 1s;
  height: 32px;
  width: 32px;
}

div[data-rewards-widget].medallion .gaining-points-animation svg.outer-circle-animation circle {
  stroke: var(--rw-color, var(--rw-medal-color));
  fill: none;
  stroke-width: 2;
}

div[data-rewards-widget].medallion .gaining-points-animation .medal-animation-container {
  position: absolute;
  top: 0px;
  height: 32px;
  width: 32px;
}

div[data-rewards-widget].medallion .gaining-points-animation .medal-svg-animation {
  position: relative;
  animation: rw-gp-expand-collapse 0.3s cubic-bezier(0.075, 0.82, 0.165, 1);
  animation-delay: 1s;
}

div[data-rewards-widget].medallion .gaining-points-animation .outer-circle-animation circle {
  fill: none;
  stroke: var(--rw-color, var(--rw-medal-color));
  stroke-width: 2;
  stroke-dasharray: 100.53, 100.53;
  stroke-dashoffset: 100.53;
  animation: rw-gp-animate-circle 1s linear forwards;
}

div[data-rewards-widget].medallion .gaining-points-animation .medal-svg-animation {
  position: relative;
  animation: rw-gp-expand-collapse 0.3s cubic-bezier(0.075, 0.82, 0.165, 1);
  animation-delay: 1s;
  fill: var(--rw-color, var(--rw-medal-color));
}

@keyframes rw-gp-animate-circle {
  to {
    stroke-dashoffset: 0;
  }
}

@keyframes rw-gp-expand-collapse {
  0% {
    transform: scale(1);
  }
  70% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

/*# sourceMappingURL=data:application/json;charset=utf-8;base64, */div[data-rewards-widget].medallion .goal-tracking-container {
  width: 32px;
  height: 32px;
}

div[data-rewards-widget].medallion .medal-goal-track-meter {
  width: 32px;
  height: 32px;
  position: absolute;
  transform: rotate(-90deg);
}

div[data-rewards-widget].medallion .medal-goal-track-meter circle {
  stroke: var(--rw-color, var(--rw-medal-color));
}

div[data-rewards-widget].medallion .goal-track-medal-type {
  width: 32px;
  height: 32px;
  fill: var(--rw-color, var(--rw-medal-color));
}

div[data-rewards-widget].medallion .goal-track-outer-circle {
  width: 32px;
  height: 32px;
  position: absolute;
  stroke: var(--rw-color, var(--rw-medal-color));
  opacity: 0.4;
}

/*# sourceMappingURL=data:application/json;charset=utf-8;base64, */#rewid-af {
  position: absolute;
  z-index: 10;
  top: 50px;
  right: 0;
  font-size: 0;
  box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.1), 0 2px 4px 1px rgba(0, 0, 0, 0.18);
  border-radius: 5px;
}

#rewid-af:dir(rtl) {
  right: auto;
  left: 0;
}

#rewid-af iframe {
  border-radius: 5px;
}

/*# sourceMappingURL=data:application/json;charset=utf-8;base64, */#rewid-f {
  position: fixed;
  right: 0;
  top: 0;
  width: 376px;
  height: 100vh;
  z-index: 1100;
  box-shadow: 0 0 0 1px #0000000d, 0 0 0 2px #0000001a;
}

.b_pinhead #b_header #id_h #id_rh_w #rewid-f {
  visibility: visible;
}

#rewid-f.modern {
  position: absolute;
  z-index: 10;
  top: 50px;
  right: 0;
  font-size: 0;
  width: 0vh;
  height: 0vh;
  visibility: none;
}

#rewid-f.modern iframe {
  border-radius: 5px;
}

#rewid-f:dir(rtl) {
  right: auto;
  left: 0;
}

/*# sourceMappingURL=data:application/json;charset=utf-8;base64, */div[data-rewards-widget].medallion.rw-dark {
  --rw-medal-color: #a2b7f4;
  --rw-medal-color-glow: #4a9eff;
  --rw-font-color: #edebe9;
  --rw-red-dot-color: #ff4c4c;
}

div[data-rewards-widget].medallion {
  --rw-medal-color: #174ae4;
  --rw-medal-color-glow: #1e90ff;
  --rw-font-color: #333333;
  --rw-red-dot-color: #c80000;
  --rw-red-dot-diameter: 7px;
  display: inline-block;
  cursor: pointer;
  position: relative;
}

div[data-rewards-widget].medallion:not(.copilotSearch) > div {
  display: flex;
  align-items: center;
  text-decoration: none;
  height: 100%;
  padding: 0 4px;
}

div[data-rewards-widget].medallion:not(.copilotSearch) > div > * {
  padding: 0 4px;
  display: flex;
}

div[data-rewards-widget].medallion:not(.copilotSearch) .points-container {
  color: var(--rw-color, var(--rw-font-color));
  font-family: var(--rw-font-family);
  font-feature-settings: 'tnum';
  font-variant-numeric: tabular-nums;
  display: inline-block;
  text-align: right;
}

div[data-rewards-widget].medallion:not(.copilotSearch) div.medal {
  position: relative;
}

@keyframes rw-medal-ripple {
  0% {
    box-shadow: 0 0 0 0 rgba(78, 131, 246, 0), 0 0 0 2px rgba(78, 131, 246, 1);
    opacity: 1;
  }

  20% {
    box-shadow: 0 0 0 2px rgba(78, 131, 246, 0.5), 0 0 0 2px rgba(78, 131, 246, 0.8);
    opacity: 1;
  }

  50% {
    box-shadow: 0 0 0 6px rgba(78, 131, 246, 0.3), 0 0 0 2px rgba(78, 131, 246, 0.5);
    opacity: 0.8;
  }

  80% {
    box-shadow: 0 0 0 8px rgba(78, 131, 246, 0.15), 0 0 0 2px rgba(78, 131, 246, 0.2);
    opacity: 0.3;
  }

  100% {
    box-shadow: 0 0 0 12px rgba(78, 131, 246, 0), 0 0 0 2px rgba(78, 131, 246, 0);
    opacity: 0;
  }
}

div[data-rewards-widget].medallion.glow-medal:not(.copilotSearch):not(.frozen):not(.ocean-commotion) div.medal::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 29px;
  height: 29px;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  opacity: 0;
  animation: rw-medal-ripple 1s ease-out 3;
  pointer-events: none;
}

div[data-rewards-widget].medallion:not(.copilotSearch) svg.medal-circled {
  width: 32px;
  height: 32px;
  fill: var(--rw-color, var(--rw-medal-color));
}

div[data-rewards-widget].medallion svg.medal-new-level {
  width: 20px;
  height: 20px;
}

div[data-rewards-widget].medallion svg.medal-newlevel-circled {
  width: 32px;
  height: 32px;
}

div[data-rewards-widget].medallion svg.medal-circled circle {
  stroke: var(--rw-color, var(--rw-medal-color));
}

div[data-rewards-widget].medallion .light-ring svg.medal-circled circle {
  opacity: 0.3;
}

div[data-rewards-widget].medallion svg.medal-light {
  width: 32px;
  height: 32px;
  fill: var(--rw-color, var(--rw-medal-color));
}

div[data-rewards-widget].medallion .red-dot {
  width: var(--rw-red-dot-diameter);
  height: var(--rw-red-dot-diameter);
  border-radius: 50%;
  background-color: var(--rw-red-dot-color);
  top: -3px;
  right: 1px;
  position: absolute;
}

div[data-rewards-widget].medallion .red-dot.adjacent {
  right: 0;
  top: 0;
}

/* Copilot Search styles*/
div[data-rewards-widget].medallion.copilotSearch .points-container {
  color: var(--acf-color-fore-neutral-quaternary, rgba(0, 0, 0, 0.6));
  text-align: center;
  font-size: 13px;
  font-style: normal;
  font-weight: 400;
  line-height: 20px;
}

div[data-rewards-widget].medallion.copilotSearch .b_clickarea:hover .points-container {
  color: var(--acf-color-fore-neutral-secondary, rgba(0, 0, 0, 0.8));
}

div[data-rewards-widget].medallion.copilotSearch.rw-dark .points-container {
  color: var(--acf-color-fore-neutral-quaternary, rgba(255, 255, 255, 0.6));
}

div[data-rewards-widget].medallion.copilotSearch.rw-dark .b_clickarea:hover .points-container {
  color: var(--acf-color-fore-neutral-secondary, rgba(255, 255, 255, 0.8));
}

div[data-rewards-widget].medallion.copilotSearch div.medal {
  display: flex;
  align-items: center;
  justify-content: inherit;
}

div[data-rewards-widget].medallion.copilotSearch svg.medal-circled {
  fill: black;
  height: 17px;
  fill-opacity: 0.6;
}

div[data-rewards-widget].medallion.copilotSearch .b_clickarea:hover svg.medal-circled {
  fill: #202020;
  fill-opacity: unset;
}

div[data-rewards-widget].medallion.copilotSearch.rw-dark svg.medal-circled {
  fill: white;
}

div[data-rewards-widget].medallion.copilotSearch.rw-dark .b_clickarea:hover svg.medal-circled {
  fill: #cfdeff;
}

